@{
    ViewBag.Title = "Trang Chủ";
    Layout = "~/Views/Shared/_LayoutHomePage.cshtml";
}

@model IEnumerable<ProTechTiveGear.Models.Item>

<style>
    /* ================= DANH SÁCH SẢN PHẨM ================= */
    .product_section {
        background-color: #fdfdfd;
        padding: 80px 0;
    }
    .main_title {
        text-align: center;
        margin-bottom: 50px;
    }
    .main_title h2 {
        font-size: 32px;
        font-weight: 700;
        color: #2d2d2d;
        text-transform: uppercase;
        position: relative;
        display: inline-block;
        padding-bottom: 10px;
    }
    .main_title h2::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 50%;
        transform: translateX(-50%);
        width: 60px;
        height: 3px;
        background-color: #008b8b; 
    }

    /* Product Card */
    .product-card {
        background: #fff;
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid #eaeaea;
        transition: all 0.3s ease;
        margin-bottom: 30px;
        position: relative;
        display: flex;
        flex-direction: column;
        height: 100%;
    }
    .product-card:hover {
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
        transform: translateY(-5px);
    }
    
    /* Product Image */
    .product-img-box {
        position: relative;
        overflow: hidden;
        aspect-ratio: 1 / 1; 
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: #f9f9f9;
    }
    .product-img-box img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        transition: transform 0.5s ease;
        padding: 15px;
    }
    .product-card:hover .product-img-box img {
        transform: scale(1.08);
    }

    /* Badge Out of Stock */
    .out-of-stock-badge {
        position: absolute;
        top: 10px;
        right: 10px;
        background-color: #dc3545;
        color: white;
        padding: 5px 12px;
        font-size: 12px;
        font-weight: 600;
        border-radius: 20px;
        z-index: 2;
        box-shadow: 0 4px 10px rgba(220, 53, 69, 0.3);
    }
    .out-of-stock-overlay {
        position: absolute;
        inset: 0;
        background: rgba(255,255,255,0.5);
        z-index: 1;
    }

    /* Product Info */
    .product-info {
        padding: 20px 15px;
        text-align: center;
        flex-grow: 1;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }
    .product-title {
        font-size: 15px;
        font-weight: 600;
        color: #333;
        margin-bottom: 10px;
        display: -webkit-box;
        -webkit-line-clamp: 2; 
        -webkit-box-orient: vertical;
        overflow: hidden;
        text-decoration: none;
        transition: color 0.3s;
    }
    .product-title:hover {
        color: #008b8b;
        text-decoration: none;
    }
    .product-price {
        font-size: 18px;
        font-weight: 700;
        color: #d32f2f; 
        margin-bottom: 15px;
    }

    /* Add to cart Button */
    .btn-add-cart {
        display: block;
        width: 100%;
        padding: 14px 0;
        background-color: #008b8b;
        color: #fff;
        font-weight: 600;
        text-transform: uppercase;
        font-size: 13px;
        text-decoration: none;
        transition: all 0.3s ease;
        border-top: 1px solid #f0f0f0;
        text-align: center; /* Đã bổ sung căn giữa chữ */
    }
    .btn-add-cart i {
        margin-right: 6px;
        font-size: 15px;
    }
    .btn-add-cart:hover {
        background-color: #A0522D;
        color: #fff;
        text-decoration: none;
    }
    .btn-add-cart.disabled {
        background-color: #d6d6d6;
        color: #888;
        cursor: not-allowed;
        pointer-events: none; /* Chặn click hoàn toàn */
    }

    /* ================= NEW ARRIVAL SECTION ================= */
    .new_arivals_area {
        background-color: #f6f6f6;
        padding: 80px 0;
    }
    .featured-banner {
        background: #fff;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 8px 25px rgba(0,0,0,0.06);
        display: flex;
        align-items: center;
        padding: 25px;
        height: 100%;
        transition: transform 0.3s ease;
    }
    .featured-banner:hover {
        transform: translateY(-5px);
    }
    .featured-banner img {
        width: 45%;
        object-fit: cover;
        border-radius: 8px;
    }
    .featured-info {
        width: 55%;
        padding-left: 25px;
    }
    .featured-info h5 {
        color: #d32f2f;
        font-weight: 700;
        font-size: 26px;
        margin-bottom: 12px;
    }
    .featured-info h4 {
        font-size: 18px;
        color: #333;
        font-weight: 600;
        line-height: 1.5;
    }
    .featured-info .tag {
        display: inline-block;
        background-color: #008b8b;
        color: #fff;
        padding: 6px 12px;
        border-radius: 6px;
        font-size: 13px;
        margin-top: 15px;
        font-weight: 500;
    }
</style>

<section class="product_section">
    <div class="container">
        <div class="main_title">
            <h2>Sản phẩm nổi bật</h2>
        </div>
        
        <div class="row">
            @if(Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <div class="col-lg-3 col-md-4 col-sm-6 col-12">
                        <div class="product-card">
                            <a href="@Url.Action("Detail","AuraStore", new { id=item.ID })" class="product-img-box">
                                @if (item.Quantity == 0)
                                {
                                    <span class="out-of-stock-badge">Hết hàng</span>
                                    <div class="out-of-stock-overlay"></div>
                                }
                                <img src="~/img/Item/@item.Picture" alt="@item.Name">
                            </a>

                            <div class="product-info">
                                <a href="@Url.Action("Detail","AuraStore", new { id=item.ID })" class="product-title">
                                    @item.Name
                                </a>
                                <div class="product-price">
                                    @* Đã tự động format dấu phẩy tiền tệ VNĐ *@
                                    @string.Format("{0:0,0} đ", item.SellPrice)
                                </div>
                            </div>

                            @if (item.Quantity == 0)
                            {
                                <a class="btn-add-cart disabled" href="javascript:void(0);">
                                    <i class="fa fa-ban"></i> Hết hàng
                                </a>
                            }
                            else
                            {
                                <a class="btn-add-cart" href="@Url.Action("AddtoCart","Cart", new { @id=item.ID, @strURL=Request.Url.ToString() })">
                                    <i class="fa fa-cart-plus"></i> Thêm vào giỏ
                                </a>
                            }
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center">
                    <p style="color: #777; font-size: 16px;">Hiện chưa có sản phẩm nào.</p>
                </div>
            }
        </div>
    </div>
</section>

<section class="new_arivals_area">
    <div class="container">
        <div class="main_title">
            <h2>Sản phẩm mới</h2>
        </div>

        <div class="row">
            <div class="col-lg-5 col-md-12 mb-4">
                <div class="featured-banner">
                    <img class="img-fluid" src="https://product.hstatic.net/200000420363/product/ram-pioneer-udimm-16gb-ddr4-3200mhz-tan-nhiet_6083e878c7084ddb9d19d965816d4289_large.jpg" alt="Ram Pioneer">
                    <div class="featured-info">
                        <h5>610,000 đ</h5>
                        <h4>Ram Pioneer UDIMM <br/>DDR4 3200MHz</h4>
                        <span class="tag"><i class="fa fa-microchip" aria-hidden="true"></i> 16GB</span>
                    </div>
                </div>
            </div>

            <div class="col-lg-7 col-md-12">
                <div class="row">
                    @Html.Action("Newdproducts", "AuraStore")
                </div>
            </div>
        </div>
    </div>
</section>